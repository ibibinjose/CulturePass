# ──────────────────────────────────────────────────────────────────────────────
# CulturePass — Environment variables
# Copy to `.env` and fill values. Never commit `.env`.
# EAS production: set the same EXPO_PUBLIC_* names in Expo → Project → Environment
# variables (Production), or `eas secret:create --name VAR --value ... --scope project`
# Do not commit live API keys or Stripe keys in eas.json.
# ──────────────────────────────────────────────────────────────────────────────

# Firebase (Console → Project settings → Your apps → Web)
# Required for `npm run deploy-web` (keys are baked in at `expo export`).
# Optional for CI: use `build-web:with-mock-firebase`.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase App Check — Web reCAPTCHA v3 site key (Console → App Check → Register web app).
# Optional until you turn on enforcement; omit locally if unused.
EXPO_PUBLIC_APPCHECK_SITE_KEY=

# Cloud Functions HTTP API (trailing slash optional; app normalizes).
# Do not set this to http://localhost:5001/.../api/ unless EXPO_PUBLIC_USE_FIREBASE_EMULATORS=true
# (production Auth tokens are not verifiable on the Functions emulator without Auth emulator).
EXPO_PUBLIC_API_URL=https://us-central1-<project-id>.cloudfunctions.net/api/

# EAS / Expo Push — same UUID as app.json → expo.extra.eas.projectId
EXPO_PUBLIC_EAS_PROJECT_ID=

# Stripe publishable key (pk_live_… / pk_test_…); safe in client; configure in EAS for store builds.
# Stripe secret + webhook secret must be set as Firebase secrets (never in .env):
#   firebase functions:secrets:set STRIPE_SECRET_KEY
#   firebase functions:secrets:set STRIPE_WEBHOOK_SECRET
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Firebase emulators (local only). Keep false unless you intentionally run Auth + Functions emulators;
# true with production Auth causes 401s against localhost:5001.
EXPO_PUBLIC_USE_FIREBASE_EMULATORS=false
EXPO_PUBLIC_FIREBASE_EMULATOR_HOST=localhost

# Google Sign-In + Maps (Maps: Android native + iOS plist substitution via app.json)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_MAPS_KEY=
EXPO_PUBLIC_GOOGLE_REVERSED_CLIENT_ID=

# Native OAuth client files are not committed. Download from Firebase Console after
# adding iOS bundle ID `au.culturepass.app` and Android package `au.culturepass.app`
# with the release SHA-1/SHA-256 fingerprints:
#   - GoogleService-Info.plist
#   - google-services.json

# Firebase Cloud Messaging — Web Push VAPID key
# (Console → Project settings → Cloud Messaging → Web Push certificates → Key pair)
EXPO_PUBLIC_FCM_VAPID_KEY=

# Analytics
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Canonical web origin for shares / universal links (matches Firebase Hosting apex).
# Client: used by lib/publicPaths `siteUrl()`. Defaults to https://culturepass.app if unset.
EXPO_PUBLIC_SITE_ORIGIN=https://culturepass.app

# ── Firebase Cloud Functions only (not Expo) ─────────────────────────────────
# Wallet pass download links & in-pass "Open in app" URLs:
#   PUBLIC_APP_ORIGIN — same as EXPO_PUBLIC_SITE_ORIGIN (profile/ticket deep links, pass webService default).
#   WALLET_LINKS_PUBLIC_ORIGIN — optional; stable HTTPS host for .pkpass download URLs.
#     When set, overrides the request Host (avoids cloudfunctions.net links on phones).
#   PUBLIC_APP_ICON_URL — optional; full URL to PNG for Google Wallet class logo
#     (defaults to PUBLIC_APP_ORIGIN/icon.png).
# See functions/src/services/walletPasses.ts for Apple/Google cert env vars.
# PUBLIC_APP_ORIGIN=https://culturepass.app
# WALLET_LINKS_PUBLIC_ORIGIN=https://culturepass.app
# PUBLIC_APP_ICON_URL=
