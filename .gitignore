.claude/
node_modules/

# JetBrains / IntelliJ — IDE-local state (workspace.xml, caches); do not commit
.idea/

# Expo local state, caches, and build logs (regenerated by the CLI)
.expo/

# Local agent/tool outputs (not app source)
.gstack/
.kiro/
.junie/
skills-lock.json

# Firebase emulator debug logs (regenerated locally)
firestore-debug.log
firebase-debug.log
database-debug.log
ui-debug.log

# Editor / tool backup files
*.bak
*.backup

# Regenerated test / CI artifacts
junit.xml

# Optional local dev notes (keep out of VCS)
.log.md

# Build outputs (web export + Functions compile)
dist/
functions/lib/

# Never nest a git repo inside functions/ (Cloud Functions live in this monorepo)
functions/.git/

# EAS / native build artifacts
*.aab
*.apk
*.ipa
build-*.aab
build-*.apk

# Environment secrets — never commit real keys
.env
.env.local
.env.*.local
.sentryclirc

# Signing credentials & secrets — NEVER commit plaintext passwords/keys
credentials.json
credentials/
*.jks
*.keystore
*.p8
*.p12
*.key
mykey.key
GoogleService-Info.plist
google-services.json
google-play-service-account.json

# Wallet provisioning temp dir — GCP SA keys, pass exports, signer PEMs
temp-certs/*.json
temp-certs/*.p12
temp-certs/*.pem
temp-certs/pass-from-keychain.p12

# Firebase deploy cache
.firebase/

# iOS local env
ios/.xcode.env.local

# Coverage output
coverage/

# Sentry wizard error logs (leftover from removed integration)
sentry-wizard-installation-error-*.log

# macOS — Finder metadata and AppleDouble resource forks
.DS_Store
._*
.AppleDouble
.LSOverride

.env.local
