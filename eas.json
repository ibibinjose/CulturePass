{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "base": {
      "node": "22.14.0",
      "env": {
        "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD": "1",
        "NPM_CONFIG_PRODUCTION": "false",
        "EXPO_PUBLIC_API_URL": "https://australia-southeast1-culturepass-4f264.cloudfunctions.net/api/",
        "EXPO_PUBLIC_EAS_PROJECT_ID": "9dc511ee-ee3e-4798-ae29-30efc8f5343e",
        "EXPO_PUBLIC_SITE_ORIGIN": "https://culturepass.app",
        "EXPO_PUBLIC_STRIPE_MERCHANT_IDENTIFIER": "merchant.au.culturepass.app",
        "EXPO_PUBLIC_POSTHOG_HOST": "https://us.i.posthog.com",
        "EXPO_PUBLIC_USE_FIREBASE_EMULATORS": "false"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "cache": {
        "disabled": true
      },
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_STRIPE_ANDROID_PAY_MODE": "test"
      }
    },
    "development-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_STRIPE_ANDROID_PAY_MODE": "test"
      }
    },
    "production": {
      "extends": "base",
      "channel": "production",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_STRIPE_ANDROID_PAY_MODE": "production"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "AirPizza@icloud.com",
        "ascAppId": "6761712952",
        "appleTeamId": "26WGXSNG58"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "production"
      }
    }
  }
}