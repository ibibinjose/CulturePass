# Cloud Functions / Firebase — set via Firebase Console → Functions → Configuration
# or `firebase functions:secrets:set` (recommended for production). Do not commit real values.

# Stripe (server only)
# Preferred server key. Use a restricted key (`rk_...`) with least-privilege permissions for this Functions API.
STRIPE_API_KEY=
# Legacy fallback. Prefer STRIPE_API_KEY for new Stripe accounts.
STRIPE_SECRET_KEY=
# Optional server echo for mobile PaymentIntent responses. Keep this in sync with EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY.
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret — endpoint must receive Connect event: account.updated (plus existing checkout/subscription events)
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY_ID=
STRIPE_PRICE_YEARLY_ID=

# Optional — CultureShop first-time Plus discount (create a 50% coupon in Stripe Dashboard)
STRIPE_COUPON_FIRST_PREMIUM_HALF_OFF=

# Optional — Firebase users/{uid}.approvedMarketplacePublisher lets organisers publish CultureShop deals
# Stripe Connect — marketplace application fee (basis points). Default in code is 1000 (= 10%).
STRIPE_CONNECT_PLATFORM_FEE_BPS=1000
FIREBASE_STORAGE_BUCKET=
ROLLOUT_PHASE=internal

# Apple Wallet pass signing (if using pass generation)
APPLE_PASS_SIGNER_KEY_PASSPHRASE=

# Local emulator seed only (`npm run seed:emulator:cap` from functions/, or `npm run emulator:seed:cap` from repo root).
# Script forces FIRESTORE_EMULATOR_HOST / FIREBASE_AUTH_EMULATOR_HOST defaults — do not use in production deploys.
# SEED_TEST_EMAIL=cap-emulator@test.local
# SEED_TEST_PASSWORD=
# SEED_PROJECT_ID=culturepass-4f264
