# CultureHost — Environment Variables
# Copy to .env and fill in values from Firebase Console + Google Cloud Console.
# All EXPO_PUBLIC_* vars are baked into the bundle at build time.

# --- Firebase (same project as consumer app) ---
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=culturepass-4f264.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=culturepass-4f264
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=culturepass-4f264.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=476251116440
EXPO_PUBLIC_FIREBASE_APP_ID=

# --- Backend API ---
EXPO_PUBLIC_API_URL=https://us-central1-culturepass-4f264.cloudfunctions.net/api/
# Local dev: EXPO_PUBLIC_API_URL=http://localhost:5001/culturepass-4f264/us-central1/api/

# --- Google Sign-In ---
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_REVERSED_CLIENT_ID=

# --- Local dev emulators ---
# EXPO_PUBLIC_USE_FIREBASE_EMULATORS=true
# EXPO_PUBLIC_FIREBASE_EMULATOR_HOST=127.0.0.1
