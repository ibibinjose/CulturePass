{
  "name": "culturepass-app",
  "version": "1.2.2",
  "main": "expo-router/entry",
  "scripts": {
    "start": "npx expo start",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "web": "npx expo start --web",
    "server:dev": "tsx functions/src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:unit": "jest && npm run test:functions",
    "test:functions": "cd functions && npm test",
    "test:integration": "jest \"scripts/tests/integration-.*\\.ts$\"",
    "test:e2e": "playwright test",
    "test:property": "tsx scripts/tests/property-tests.ts",
    "test:load": "tsx scripts/tests/load-tests.ts",
    "test:functional": "node scripts/run-functional-tests.js",
    "build": "npx expo export --platform web",
    "build-web": "npx expo export --platform web",
    "build:ios:development": "eas build --platform ios --profile development",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:ios:production": "eas build --platform ios --profile production",
    "build:android:development": "eas build --platform android --profile development",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:production": "eas build --platform android --profile production",
    "update:preview": "eas update --channel preview",
    "update:production": "eas update --channel production",
    "deploy": "npm run build-web && npx firebase-tools deploy",
    "deploy-web": "npm run build-web && npx firebase-tools deploy --only hosting",
    "deploy-functions": "cd functions && npm run deploy",
    "deploy:guarded": "npm run qa:solid && npm run deploy",
    "db:nuke-all": "echo '⚠️  This deletes ALL Firestore data. Press Ctrl+C to cancel.' && sleep 5 && npx firebase-tools firestore:delete --all-collections --non-interactive --project $FIREBASE_PROJECT_ID",
    "emulator:start": "npx firebase-tools emulators:start --only functions,firestore,auth,storage",
    "emulator:seed:cap": "tsx scripts/emulator/seeds/cap-seed.ts",
    "emulator:seed:all": "tsx scripts/emulator/seeds/all-seeds.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "qa:solid": "npm run typecheck && npm run lint && npm run test:unit",
    "security:audit": "npm audit --legacy-peer-deps",
    "security:audit:functions": "cd functions && npm audit --legacy-peer-deps",
    "security:audit:fix": "npm audit fix --legacy-peer-deps",
    "security:audit:force": "npm audit fix --force --legacy-peer-deps",
    "security:eslint": "npm run lint -- --max-warnings 0 --legacy-peer-deps",
    "security:all": "npm run security:audit && npm run security:audit:functions && npm run security:eslint && npm run test:unit && npm run test:integration",
    "dev": "npx expo start --dev-client",
    "doctor": "node scripts/doctor.js",
    "dev:full": "npm run doctor && echo '✅ Doctor passed. Starting emulators + Expo...' && npm run emulator:start & sleep 8 && npx expo start --clear",
    "size:web": "node scripts/check-web-bundle-size.js",
    "size:web:ci": "npm run build-web && node scripts/check-web-bundle-size.js",
    "clean": "rm -rf node_modules && rm -rf functions/node_modules && rm -rf dist && rm -rf .expo",
    "backup": "bash scripts/backup.sh"
  },
  "dependencies": {
    "@bacons/apple-targets": "4.0.6",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/newsreader": "^0.4.1",
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo/ui": "~55.0.17",
    "@expo/vector-icons": "^15.0.2",
    "@hookform/resolvers": "^3.10.0",
    "@posthog/core": "^1.29.9",
    "@posthog/types": "^1.376.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@sentry/react": "^8.55.2",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/query-async-storage-persister": "^5.100.9",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-persist-client": "^5.100.9",
    "buffer": "^6.0.3",
    "date-fns": "^4.1.0",
    "expo": "~55.0.23",
    "expo-apple-authentication": "~55.0.13",
    "expo-application": "~55.0.15",
    "expo-blur": "~55.0.14",
    "expo-build-properties": "~55.0.14",
    "expo-calendar": "~55.0.15",
    "expo-camera": "~55.0.19",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.16",
    "expo-contacts": "~55.0.14",
    "expo-crypto": "~55.0.15",
    "expo-dev-client": "~55.0.35",
    "expo-device": "~55.0.17",
    "expo-file-system": "~55.0.22",
    "expo-font": "~55.0.8",
    "expo-glass-effect": "~55.0.11",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.11",
    "expo-image-manipulator": "~55.0.17",
    "expo-image-picker": "~55.0.20",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-local-authentication": "~55.0.14",
    "expo-localization": "~55.0.15",
    "expo-location": "~55.1.10",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.14",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.9",
    "expo-system-ui": "~55.0.18",
    "expo-updates": "~55.0.24",
    "expo-web-browser": "~55.0.16",
    "expo-widgets": "~55.0.0",
    "fbjs": "^3.0.5",
    "firebase": "^12.13.0",
    "i18next": "^26.2.0",
    "posthog-react-native": "^4.45.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.76.1",
    "react-i18next": "^17.0.8",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-maps": "1.27.2",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4",
    "zod": "^4.4.3",
    "zod-validation-error": "^5.0.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@playwright/test": "^1.60.0",
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.16",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "babel-preset-expo": "~55.0.0",
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.8.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.0",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "@sentry/cli": "^2.58.4"
  },
  "private": true,
  "engines": {
    "node": ">=22.14.0 <23"
  }
}
